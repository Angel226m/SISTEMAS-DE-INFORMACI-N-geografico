# GeoRiesgo Ica — Variables de entorno
# Coloca este archivo en la RAÍZ del proyecto (mismo nivel que docker-compose.yml)

# Base de datos
DB_PASSWORD=georiesgo_secret
POSTGRES_DB=georiesgo
POSTGRES_USER=georiesgo
DB_HOST=db
DB_PORT=5432

# URLs de conexión (construidas automáticamente por docker-compose)
DATABASE_URL=postgresql+asyncpg://georiesgo:georiesgo_secret@db:5432/georiesgo
DATABASE_URL_SYNC=postgresql://georiesgo:georiesgo_secret@db:5432/georiesgo

# App
APP_ENV=production
LOG_LEVEL=INFO

# ETL: forzar re-descarga completa al arrancar (0=no, 1=sí)
FORCE_SYNC=0