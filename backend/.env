# ══════════════════════════════════════════════════════════
# GeoRiesgo Perú — Variables de entorno v4.0
# Copiar a .env y ajustar valores
# ══════════════════════════════════════════════════════════

# ── Base de datos ───────────────────────────────────────────
DB_PASSWORD=georiesgo_secret
POSTGRES_DB=georiesgo
POSTGRES_USER=georiesgo
DB_HOST=db
DB_PORT=5432

# URLs de conexión (construidas automáticamente por docker-compose)
DATABASE_URL=postgresql://georiesgo:georiesgo_secret@db:5432/georiesgo
DATABASE_URL_SYNC=postgresql://georiesgo:georiesgo_secret@db:5432/georiesgo

# Exponer puerto de BD al host (comentar en producción)
DB_PORT_EXPOSE=5432

# ── App ─────────────────────────────────────────────────────
APP_ENV=production        # production | development
LOG_LEVEL=INFO
WORKERS=2                 # uvicorn workers (recomendado: 2 * CPUs)

# ── ETL ─────────────────────────────────────────────────────
# 0 = No re-sincronizar al arrancar (BD ya tiene datos)
# 1 = Forzar re-sincronización completa al arrancar
FORCE_SYNC=0

# ── Opcionales ──────────────────────────────────────────────
# TZ=America/Lima