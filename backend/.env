# ── GeoRiesgo Ica — Variables de entorno ──────────────────
# Copia este archivo a .env y ajusta los valores

# Base de datos
DB_PASSWORD=georiesgo_secret
POSTGRES_DB=georiesgo
POSTGRES_USER=georiesgo
DB_HOST=db
DB_PORT=5432

# Construidas automáticamente por docker-compose
DATABASE_URL=postgresql+asyncpg://georiesgo:georiesgo_secret@db:5432/georiesgo
DATABASE_URL_SYNC=postgresql://georiesgo:georiesgo_secret@db:5432/georiesgo

# App
APP_ENV=production        # production | development
LOG_LEVEL=INFO

# ETL: forzar re-sincronización al arrancar (0=no, 1=sí)
FORCE_SYNC=0
